$ -----------------------------------------------------------------------------
$ KONFIGURACJA ЕҡRODOWISKA (Zmienne Globalne i Funkcja)
$ -----------------------------------------------------------------------------
!make INT global_tempo <- 125 ;
!make STRING user_name <- "Aleksander" ;
!make INT global_unassigned ; $ Celowo zostawiona bez wartoЕӣci startowej

!define VOID playMelody <INT duration> {
    !shout "Playing melody for:" ;
    !shout duration ;
}

$ -----------------------------------------------------------------------------
$ GЕҒГ“WNY BLOK PROGRAMU
$ -----------------------------------------------------------------------------
{
    !make INT current_volume <- 90 ;
    !make NUMERICAL pi_value <- 3.1415 ;
    !make INT local_unassigned ; $ Kolejna zmienna bez wartoЕӣci
    !make ARRAY track_events ;    $ Tablice sД… domyЕӣlnie inicjalizowane jako []

    $ =========================================================================
    $ CZДҳЕҡДҶ 1: TESTY SUGEROWANIA LITERГ“WEK ("Did you mean...?")
    $ =========================================================================

    $ --- TEST 1.1: LiterГіwka w nazwie zmiennej globalnej przy przypisaniu ---
    $ Oczekiwany bЕӮД…d: Cannot assign to undefined variable 'global_tempa'. Suggestion: Did you mean 'global_tempo'?
    $ global_tempa <- 140 ;

    $ --- TEST 1.2: LiterГіwka w bloku lokalnym przy odczycie (TargetExpr) ---
    $ Oczekiwany bЕӮД…d: Variable 'current_volum' is not defined. Suggestion: Did you mean 'current_volume'?
    $ !make INT new_vol <- current_volum + 10 ;

    $ --- TEST 1.3: LiterГіwka w nazwie wywoЕӮywanej funkcji (TypeChecker) ---
    $ Oczekiwany bЕӮД…d: Function 'playMelodi' is not defined. Suggestion: Did you mean 'playMelody'?
    $ !make INT zapychacz <- playMelodi(500) ;


    $ =========================================================================
    $ CZДҳЕҡДҶ 2: TESTY NIEZAINICJALIZOWANYCH ZMIENNYCH
    $ =========================================================================

    $ --- TEST 2.1: UЕјycie lokalnej pustej zmiennej w operacji matematycznej ---
    $ Oczekiwany bЕӮД…d: [Error] Variable 'local_unassigned' is declared but uninitialized.
    $ !make INT crash_test <- local_unassigned + 10 ;

    $ --- TEST 2.2: UЕјycie globalnej pustej zmiennej ---
    $ Oczekiwany bЕӮД…d: [Error] Variable 'global_unassigned' is declared but uninitialized.
    $ current_volume <- global_unassigned ;


    $ =========================================================================
    $ CZДҳЕҡДҶ 3: LEGALNA ЕҡCIEЕ»KA I ZRZUT PAMIДҳCI (!debug)
    $ =========================================================================
    
    $ Ta sekcja wykona siДҷ bezbЕӮДҷdnie, jeЕӣli powyЕјsze testy sД… zakomentowane.
    !shout "--- Uruchamiam legalna sciezke programu ---" ;
    
    !make INT late_initialized ; $ Deklaracja pustej zmiennej
    late_initialized <- 777 ;   $ PrawidЕӮowa inicjalizacja - podnosi flagДҷ w Scope!

    !shout "Zmienna late_initialized po przypisaniu wartoЕӣci:" ;
    !shout late_initialized ;

    $ WywoЕӮujemy nasz nowy, potДҷЕјny mechanizm inspekcji stanu pamieci!
    !debug ;
}